{
  "name": "youtube-bot",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "lint": "eslint --flag unstable_native_nodejs_ts_config src",
    "lint:fix": "eslint --flag unstable_native_nodejs_ts_config src --fix",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@cloudflare/workers-types": "^4.20260629.1",
    "@eslint/js": "^10.0.1",
    "@total-typescript/tsconfig": "^1.0.4",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.4.0"
  }
}
